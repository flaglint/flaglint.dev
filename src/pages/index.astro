    }
    .trust-list li::before {
      content: "✓";
      color: var(--accent);
      font-weight: 800;
      flex: 0 0 auto;
    }
    .scope-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 14px;
      border-top: 1px solid var(--border);
      padding-top: 18px;
    }
    .scope-grid h4 {
