<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Privacy — FlagLint</title>
  <meta name="description" content="FlagLint is a local CLI. Learn what the website, CLI, and Stay updated email form collect and do not collect.">
  <meta property="og:title" content="Privacy — FlagLint">
  <meta property="og:description" content="FlagLint is a local static-analysis CLI. The website has a CLI updates form and does not collect source code.">
  <meta property="og:url" content="https://flaglint.dev/privacy">
  <meta property="og:site_name" content="FlagLint">
  <meta property="og:type" content="website">
  <meta property="og:image" content="https://flaglint.dev/og.svg">
  <meta name="twitter:card" content="summary_large_image">
  <link rel="canonical" href="https://flaglint.dev/privacy">
  <link rel="icon" href="/favicon.ico" sizes="any">
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">
  <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96.png">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png">
  <link rel="manifest" href="/site.webmanifest">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #0a0a0a;
      --surface: #111111;
      --surface-raised: #1a1a1a;
      --surface-soft: #0d1117;
      --border: #222222;
      --border-strong: #333333;
      --text: #f0f0f0;
      --text-primary: #f0f0f0;
      --text-secondary: #999999;
      --muted: #999999;
      --subtle: #666666;
      --accent: #00d97e;
      --accent-soft: rgba(0, 217, 126, 0.10);
      --code-bg: #0d1117;
      --radius: 8px;
      --transition: 0.15s ease;
    }
    html { scroll-behavior: smooth; }
    body {
      background: var(--bg);
      color: var(--text-primary);
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      font-size: 16px;
      line-height: 1.65;
    }
    a { color: var(--accent); text-decoration: none; }
    a:hover { text-decoration: underline; }
    a:focus-visible, button:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 3px;
    }
    nav {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(10,10,10,0.9);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
    }
    .nav-inner {
      max-width: 1180px;
      margin: 0 auto;
      padding: 0 24px;
      min-height: 64px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 20px;
    }
    .logo { font-size: 18px; font-weight: 700; color: var(--text-primary); text-decoration: none; }
    .nav-links {
      display: flex;
      gap: 22px;
      align-items: center;
      color: var(--muted);
      font-size: 14px;
      font-weight: 600;
    }
    .nav-links a { color: var(--muted); }
    .nav-links a:hover { color: var(--text-primary); text-decoration: none; }
    .github-btn {
      border: 1px solid var(--border-strong);
      border-radius: 6px;
      padding: 8px 12px;
      color: var(--text-primary);
      background: rgba(255,255,255,0.03);
    }
    main { max-width: 760px; margin: 0 auto; padding: 56px 24px 96px; }
    .breadcrumb { font-size: 13px; color: var(--text-secondary); margin-bottom: 32px; }
    .breadcrumb a { color: var(--text-secondary); }
    .breadcrumb a:hover { color: var(--text-primary); }
    .breadcrumb .sep { margin: 0 8px; color: #444; }
    h1 { font-size: clamp(28px, 4vw, 40px); font-weight: 700; line-height: 1.15; letter-spacing: -0.5px; margin-bottom: 12px; }
    .subtitle { font-size: 17px; color: var(--text-secondary); line-height: 1.6; margin-bottom: 48px; }
    .effective { font-size: 13px; color: #555; margin-top: 8px; }
    h2 { font-size: 20px; font-weight: 700; margin: 36px 0 12px; color: var(--text-primary); }
    p { color: var(--text-secondary); line-height: 1.7; margin-bottom: 14px; }
    p strong { color: var(--text-primary); }
    ul { padding-left: 20px; color: var(--text-secondary); line-height: 1.7; margin-bottom: 14px; }
    li { margin-bottom: 6px; }
    code {
      font-family: 'SF Mono', 'Fira Code', monospace; font-size: 13px;
      background: var(--code-bg); border: 1px solid #30363d; border-radius: 3px;
      padding: 1px 5px; color: #a5d6ff;
    }
    .callout {
      background: var(--surface); border: 1px solid var(--border);
      border-left: 3px solid var(--accent); border-radius: 0 var(--radius) var(--radius) 0;
      padding: 16px 20px; margin: 24px 0; font-size: 14px; color: var(--text-secondary);
    }
    .callout strong { color: var(--text-primary); }
    footer {
      border-top: 1px solid var(--border); padding: 28px 24px;
      max-width: 1180px; margin: 0 auto;
      display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px;
    }
    .footer-copy { font-size: 13px; color: #555; }
    .footer-links { display: flex; gap: 20px; }
    .footer-links a { font-size: 13px; color: #666; transition: color var(--transition); }
    .footer-links a:hover { color: var(--text-primary); text-decoration: none; }

    /* ── Light mode ─────────────────────────────────────────────────── */
    [data-theme="light"] {
      --bg: #f8fafb;
      --surface: #ffffff;
      --surface-raised: #f0f4f7;
      --surface-soft: #eef2f5;
      --border: #d1dbe3;
      --border-strong: #b0c0cc;
      --text: #0f1a14;
      --text-primary: #0f1a14;
      --text-secondary: #3d5a4a;
      --muted: #3d5a4a;
      --subtle: #6b8a7a;
      --accent: #007a49;
      --accent-soft: rgba(0, 122, 73, 0.10);
    }
    [data-theme="light"] nav {
      background: rgba(248,250,251,0.92);
      border-bottom-color: rgba(0,0,0,0.08);
    }
    [data-theme="light"] .github-btn {
      color: var(--text-primary);
    }
    [data-theme="light"] body {
      background: linear-gradient(180deg, #f0fdf6 0%, #f8fafb 30%, #f8fafb 100%);
    }

    /* ── Theme toggle ───────────────────────────────────────────────── */
    .theme-toggle {
      display: flex;
      align-items: center;
      gap: 2px;
      background: var(--surface-raised);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 2px;
      flex-shrink: 0;
    }
    .theme-btn {
      background: none;
      border: none;
      border-radius: 4px;
      padding: 4px 8px;
      cursor: pointer;
      color: var(--muted);
      font-size: 12px;
      font-family: inherit;
      display: flex;
      align-items: center;
      transition: background 0.1s, color 0.1s;
      line-height: 1;
    }
    .theme-btn.active,
    .theme-btn:hover {
      background: var(--accent);
      color: #fff;
    }
    [data-theme="light"] .theme-btn.active,
    [data-theme="light"] .theme-btn:hover {
      color: #fff;
    }

    /* ── Search button ──────────────────────────────────────────────── */
    .nav-search {
      display: flex;
      align-items: center;
      gap: 6px;
      background: var(--surface-raised);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 5px 10px;
      font-size: 13px;
      color: var(--muted);
      text-decoration: none;
      transition: border-color 0.15s, color 0.15s;
      white-space: nowrap;
      flex-shrink: 0;
    }
    .nav-search:hover {
      border-color: var(--accent);
      color: var(--text-primary);
      text-decoration: none;
    }
    .nav-search kbd {
      font-size: 11px;
      background: var(--surface-soft);
      border: 1px solid var(--border);
      border-radius: 3px;
      padding: 1px 4px;
      font-family: inherit;
      line-height: 1.4;
    }

    @media (max-width: 680px) {
      .nav-links a:not(.github-btn):not(.nav-search) { display: none; }
      .nav-inner { padding: 0 18px; }
      .search-label, .nav-search kbd { display: none; }
    }
  </style>
  <script>(function(){var s=localStorage.getItem('flaglint-theme')||'dark';var r=s==='auto'?(window.matchMedia('(prefers-color-scheme: dark)').matches?'dark':'light'):s;document.documentElement.setAttribute('data-theme',r);})();</script>
</head>
<body>

<nav>
  <div class="nav-inner">
    <a href="/" class="logo" aria-label="FlagLint">FlagLint</a>
    <div class="nav-links" aria-label="Primary navigation">
      <a href="/docs/">Docs</a>
      <a href="/blog/">Blog</a>
      <a href="/docs/" class="nav-search" id="nav-search-btn" title="Search docs (⌘K)" aria-label="Search documentation">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        <span class="search-label">Search</span>
        <kbd>⌘K</kbd>
      </a>
      <div class="theme-toggle" role="group" aria-label="Select theme">
        <button class="theme-btn" data-theme-value="light" title="Light mode" aria-label="Light mode">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 7a5 5 0 1 0 0 10A5 5 0 0 0 12 7zm0-2a1 1 0 0 0 1-1V2a1 1 0 0 0-2 0v2a1 1 0 0 0 1 1zm0 14a1 1 0 0 0-1 1v2a1 1 0 0 0 2 0v-2a1 1 0 0 0-1-1zm9-8h-2a1 1 0 0 0 0 2h2a1 1 0 0 0 0-2zM5 12a1 1 0 0 0-1-1H2a1 1 0 0 0 0 2h2a1 1 0 0 0 1-1z"/></svg>
        </button>
        <button class="theme-btn" data-theme-value="dark" title="Dark mode" aria-label="Dark mode">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 3a9 9 0 1 0 9 9c0-.46-.04-.92-.1-1.36a5.389 5.389 0 0 1-4.4 2.26 5.403 5.403 0 0 1-3.14-9.8c-.44-.06-.9-.1-1.36-.1z"/></svg>
        </button>
        <button class="theme-btn" data-theme-value="auto" title="Auto (system)" aria-label="Auto theme">Auto</button>
      </div>
      <a class="github-btn" href="https://github.com/flaglint/flaglint" target="_blank" rel="noopener noreferrer">GitHub</a>
    </div>
  </div>
</nav>

<main>
  <div class="breadcrumb">
    <a href="/">Home</a>
    <span class="sep">›</span>
    <span>Privacy</span>
  </div>

  <h1>Privacy</h1>
  <p class="subtitle">What this website and the FlagLint CLI do and do not collect.</p>
  <p class="effective">Effective date: 29 May 2026</p>

  <h2>CLI data handling</h2>
  <p>
    The FlagLint CLI (<code>flaglint audit</code>, <code>flaglint scan</code>, <code>flaglint migrate</code>,
    <code>flaglint validate</code>) reads source files from paths you specify on your
    local machine. It performs static AST analysis in-process and writes reports or
    transformed files to stdout or to a file path you provide.
  </p>
  <p>
    <strong>The CLI does not transmit source code, flag keys, file paths, LaunchDarkly SDK
    keys, migration reports, or any other data to FlagLint-owned infrastructure.</strong>
    Source-derived data remains local unless you explicitly upload or share it elsewhere.
  </p>

  <div class="callout">
    <strong>Reports are local.</strong> Audit reports, scan reports, migration plans, and validation SARIF files
    are treated as source-derived artifacts — they may contain file paths and flag keys from your
    codebase. They are stored wherever you write them and are not uploaded by the CLI.
  </div>

  <h2>Website data handling</h2>

  <h3 style="font-size:17px;font-weight:600;color:var(--text-primary);margin:20px 0 10px">Analytics and tracking scripts</h3>
  <p>
    <strong>flaglint.dev does not load analytics or tracking scripts.</strong>
    No JavaScript from Google Analytics, Plausible, Fathom, Mixpanel, Segment, or any
    similar analytics service is present on this website.
  </p>

  <h3 style="font-size:17px;font-weight:600;color:var(--text-primary);margin:20px 0 10px">Cookies</h3>
  <p>
    <strong>flaglint.dev does not set cookies.</strong> The static pages served by this
    domain do not use cookies for any purpose. Your browser's developer tools should
    show zero cookies from flaglint.dev.
  </p>

  <h3 id="email-updates" style="font-size:17px;font-weight:600;color:var(--text-primary);margin:20px 0 10px">Email updates</h3>
  <p>
    When you submit the <strong>Stay updated</strong> form, FlagLint collects your email
    address so we can send FlagLint CLI release announcements and important product
    updates. The form is processed by <strong>Loops</strong> through the
    <code>app.loops.so</code> newsletter form endpoint configured on the homepage.
  </p>
  <p>
    Loops processes and stores the submitted email address. As part of form operation
    and anti-abuse handling, Loops or its infrastructure may also process technical
    metadata such as IP address, timestamp, referrer, user agent, and request metadata.
    This processing is subject to
    <a href="https://loops.so/privacy" target="_blank" rel="noopener noreferrer">Loops' privacy policy</a>.
  </p>
  <p>
    FlagLint does not sell submitted email addresses or use them for unrelated advertising.
    You can unsubscribe using the link in any email. To request deletion, use
    <a href="https://github.com/flaglint/flaglint/issues" target="_blank" rel="noopener noreferrer">GitHub Issues</a>
    for general privacy requests, or
    <a href="https://github.com/flaglint/flaglint/security/advisories/new" target="_blank" rel="noopener noreferrer">GitHub Security Advisories</a>
    if the request includes sensitive information. The repository does not configure a
    dedicated privacy email address.
  </p>

  <h3 style="font-size:17px;font-weight:600;color:var(--text-primary);margin:20px 0 10px">Third-party services</h3>
  <p>
    This website is hosted on <strong>Cloudflare Pages</strong>. Cloudflare processes
    network requests as part of hosting and CDN delivery and may collect access logs
    under <a href="https://www.cloudflare.com/privacypolicy/" target="_blank" rel="noopener noreferrer">Cloudflare's privacy policy</a>.
  </p>
  <p>
    Page fonts are loaded from <strong>Google Fonts</strong> (fonts.googleapis.com,
    fonts.gstatic.com). Your browser sends a request to Google's servers to retrieve
    font files; this request is subject to
    <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">Google's privacy policy</a>.
  </p>
  <p>
    Links on this site point to GitHub (github.com) and npm (npmjs.com). Visiting
    those links is subject to their respective privacy policies. FlagLint does not
    receive data about your interactions with those third-party sites.
  </p>

  <h2>Contact</h2>
  <p>
    For privacy or security questions, use
    <a href="https://github.com/flaglint/flaglint/security/advisories/new" target="_blank" rel="noopener noreferrer">GitHub Security Advisories</a>
    for suspected vulnerabilities, or
    <a href="https://github.com/flaglint/flaglint/issues" target="_blank" rel="noopener noreferrer">GitHub Issues</a>
    for general questions.
  </p>

</main>

<footer>
  <span class="footer-copy">© 2026 FlagLint — MIT License</span>
  <div class="footer-links">
    <a href="https://github.com/flaglint/flaglint" target="_blank" rel="noopener noreferrer">GitHub</a>
    <a href="https://www.npmjs.com/package/flaglint" target="_blank" rel="noopener noreferrer">npm</a>
    <a href="/trust">Security &amp; Trust</a>
    <a href="/privacy">Privacy</a>
    <a href="https://github.com/flaglint/flaglint/issues" target="_blank" rel="noopener noreferrer">Contact</a>
  </div>
</footer>

<script>
(function() {
  var STORAGE_KEY = 'flaglint-theme';

  function getSystemTheme() {
    return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
  }

  function applyTheme(preference) {
    var resolved = preference === 'auto' ? getSystemTheme() : preference;
    document.documentElement.setAttribute('data-theme', resolved);
    localStorage.setItem(STORAGE_KEY, preference);
    document.querySelectorAll('.theme-btn').forEach(function(btn) {
      btn.classList.toggle('active', btn.dataset.themeValue === preference);
    });
  }

  document.addEventListener('DOMContentLoaded', function() {
    var saved = localStorage.getItem(STORAGE_KEY) || 'dark';
    applyTheme(saved);

    document.querySelectorAll('.theme-btn').forEach(function(btn) {
      btn.addEventListener('click', function() { applyTheme(btn.dataset.themeValue); });
    });

    window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', function() {
      if (localStorage.getItem(STORAGE_KEY) === 'auto') applyTheme('auto');
    });

    var searchBtn = document.getElementById('nav-search-btn');
    if (searchBtn) {
      searchBtn.addEventListener('click', function(e) {
        e.preventDefault();
        window.location.href = '/docs/';
      });
    }

    document.addEventListener('keydown', function(e) {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        window.location.href = '/docs/';
      }
    });
  });
})();
</script>
</body>
</html>
