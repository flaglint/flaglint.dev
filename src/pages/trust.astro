<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Trust and Security — FlagLint</title>
  <meta name="description" content="FlagLint is a local, MIT-licensed developer CLI. It performs static analysis of JavaScript and TypeScript source files entirely on your machine. No source code is uploaded.">
  <meta property="og:title" content="Trust and Security — FlagLint">
  <meta property="og:description" content="FlagLint is a local, MIT-licensed developer CLI. No source code is uploaded. No LaunchDarkly SDK key required.">
  <meta property="og:url" content="https://flaglint.dev/trust">
  <meta property="og:site_name" content="FlagLint">
  <meta property="og:type" content="website">
  <meta property="og:image" content="https://flaglint.dev/og.svg">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:site" content="@flaglintdev">
  <link rel="canonical" href="https://flaglint.dev/trust">
  <link rel="icon" href="/favicon.ico" sizes="any">
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">
  <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96.png">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png">
  <link rel="manifest" href="/site.webmanifest">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #0a0a0a;
      --surface: #111111;
      --surface-raised: #1a1a1a;
      --surface-soft: #0d1117;
      --border: #222222;
      --border-strong: #333333;
      --text: #f0f0f0;
      --text-primary: #f0f0f0;
      --text-secondary: #999999;
      --muted: #999999;
      --subtle: #666666;
      --accent: #00d97e;
      --accent-soft: rgba(0, 217, 126, 0.10);
      --code-bg: #0d1117;
      --radius: 8px;
      --transition: 0.15s ease;
    }
    html { scroll-behavior: smooth; }
    body {
      background: var(--bg);
      color: var(--text-primary);
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      font-size: 16px;
      line-height: 1.65;
    }
    a { color: var(--accent); text-decoration: none; }
    a:hover { text-decoration: underline; }
    a:focus-visible, button:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 3px;
    }
    nav {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(10,10,10,0.9);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
    }
    .nav-inner {
      max-width: 1180px;
      margin: 0 auto;
      padding: 0 24px;
      min-height: 64px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 20px;
    }
    .logo { font-size: 18px; font-weight: 700; color: var(--text-primary); text-decoration: none; }
    .nav-links {
      display: flex;
      gap: 22px;
      align-items: center;
      color: var(--muted);
      font-size: 14px;
      font-weight: 600;
    }
    .nav-links a { color: var(--muted); }
    .nav-links a:hover { color: var(--text-primary); text-decoration: none; }
    .github-btn {
      border: 1px solid var(--border-strong);
      border-radius: 6px;
      padding: 8px 12px;
      color: var(--text-primary);
      background: rgba(255,255,255,0.03);
    }
    main { max-width: 760px; margin: 0 auto; padding: 56px 24px 96px; }
    .breadcrumb { font-size: 13px; color: var(--text-secondary); margin-bottom: 32px; }
    .breadcrumb a { color: var(--text-secondary); }
    .breadcrumb a:hover { color: var(--text-primary); }
    .breadcrumb .sep { margin: 0 8px; color: #444; }
    h1 { font-size: clamp(28px, 4vw, 40px); font-weight: 700; line-height: 1.15; letter-spacing: -0.5px; margin-bottom: 12px; }
    .subtitle { font-size: 17px; color: var(--text-secondary); line-height: 1.6; margin-bottom: 48px; }
    h2 { font-size: 20px; font-weight: 700; margin: 40px 0 12px; color: var(--text-primary); }
    p { color: var(--text-secondary); line-height: 1.7; margin-bottom: 14px; }
    p strong { color: var(--text-primary); }
    ul { padding-left: 20px; color: var(--text-secondary); line-height: 1.7; margin-bottom: 14px; }
    li { margin-bottom: 6px; }
    li strong { color: var(--text-primary); }
    code {
      font-family: 'SF Mono', 'Fira Code', monospace; font-size: 13px;
      background: var(--code-bg); border: 1px solid #30363d; border-radius: 3px;
      padding: 1px 5px; color: #a5d6ff;
    }
    .statement-list {
      list-style: none; padding: 0;
      background: var(--surface); border: 1px solid var(--border);
      border-radius: var(--radius); overflow: hidden; margin-bottom: 32px;
    }
    .statement-list li {
      display: flex; align-items: flex-start; gap: 12px;
      padding: 14px 20px; border-bottom: 1px solid var(--border);
      color: var(--text-secondary); font-size: 15px; margin-bottom: 0;
    }
    .statement-list li:last-child { border-bottom: none; }
    .statement-list .check { color: var(--accent); font-size: 16px; flex-shrink: 0; margin-top: 1px; }
    .links-grid {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 12px; margin-bottom: 32px;
    }
    .link-card {
      background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius);
      padding: 16px 18px; display: flex; flex-direction: column; gap: 4px;
      transition: border-color var(--transition);
    }
    .link-card:hover { border-color: #444; text-decoration: none; }
    .link-card-label { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.07em; color: var(--accent); }
    .link-card-title { font-size: 14px; font-weight: 600; color: var(--text-primary); }
    .link-card-desc { font-size: 12px; color: var(--text-secondary); margin-top: 2px; }
    footer {
      border-top: 1px solid var(--border); padding: 28px 24px;
      max-width: 1180px; margin: 0 auto;
      display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px;
    }
    .footer-copy { font-size: 13px; color: #555; }
    .footer-links { display: flex; gap: 20px; }
    .footer-links a { font-size: 13px; color: #666; transition: color var(--transition); }
    .footer-links a:hover { color: var(--text-primary); text-decoration: none; }

    /* ── Light mode ─────────────────────────────────────────────────── */
    [data-theme="light"] {
      --bg: #f8fafb;
      --surface: #ffffff;
      --surface-raised: #f0f4f7;
      --surface-soft: #eef2f5;
      --border: #d1dbe3;
      --border-strong: #b0c0cc;
      --text: #0f1a14;
      --text-primary: #0f1a14;
      --text-secondary: #3d5a4a;
      --muted: #3d5a4a;
      --subtle: #6b8a7a;
      --accent: #007a49;
      --accent-soft: rgba(0, 122, 73, 0.10);
    }
    [data-theme="light"] nav {
      background: rgba(248,250,251,0.92);
      border-bottom-color: rgba(0,0,0,0.08);
    }
    [data-theme="light"] .github-btn {
      color: var(--text-primary);
    }
    [data-theme="light"] body {
      background: linear-gradient(180deg, #f0fdf6 0%, #f8fafb 30%, #f8fafb 100%);
    }

    /* ── Theme toggle ───────────────────────────────────────────────── */
    .theme-toggle {
      display: flex;
      align-items: center;
      gap: 2px;
      background: var(--surface-raised);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 2px;
      flex-shrink: 0;
    }
    .theme-btn {
      background: none;
      border: none;
      border-radius: 4px;
      padding: 4px 8px;
      cursor: pointer;
      color: var(--muted);
      font-size: 12px;
      font-family: inherit;
      display: flex;
      align-items: center;
      transition: background 0.1s, color 0.1s;
      line-height: 1;
    }
    .theme-btn.active,
    .theme-btn:hover {
      background: var(--accent);
      color: #fff;
    }
    [data-theme="light"] .theme-btn.active,
    [data-theme="light"] .theme-btn:hover {
      color: #fff;
    }

    /* ── Search button ──────────────────────────────────────────────── */
    .nav-search {
      display: flex;
      align-items: center;
      gap: 6px;
      background: var(--surface-raised);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 5px 10px;
      font-size: 13px;
      color: var(--muted);
      text-decoration: none;
      transition: border-color 0.15s, color 0.15s;
      white-space: nowrap;
      flex-shrink: 0;
    }
    .nav-search:hover {
      border-color: var(--accent);
      color: var(--text-primary);
      text-decoration: none;
    }
    .nav-search kbd {
      font-size: 11px;
      background: var(--surface-soft);
      border: 1px solid var(--border);
      border-radius: 3px;
      padding: 1px 4px;
      font-family: inherit;
      line-height: 1.4;
    }

    @media (max-width: 680px) {
      .nav-links a:not(.github-btn):not(.nav-search) { display: none; }
      .nav-inner { padding: 0 18px; }
      .search-label, .nav-search kbd { display: none; }
    }
    @media (max-width: 480px) {
      .links-grid { grid-template-columns: 1fr; }
    }
  </style>
  <script>(function(){var s=localStorage.getItem('flaglint-theme')||'dark';var r=s==='auto'?(window.matchMedia('(prefers-color-scheme: dark)').matches?'dark':'light'):s;document.documentElement.setAttribute('data-theme',r);})();</script>
</head>
