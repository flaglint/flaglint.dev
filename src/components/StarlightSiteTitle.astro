---
const pathname = Astro.url.pathname;
const isDocs = pathname.startsWith("/docs");
const isBlog = pathname.startsWith("/blog");
---

<div class="flaglint-titlebar sl-flex">
  <a href="/" class="site-title sl-flex" aria-label="FlagLint home">
    <span translate="no"><span class="brand-flag">Flag</span><span class="brand-lint">Lint</span></span>
  </a>
  <nav class="product-nav" aria-label="Primary sections">
    <a href="/docs/" class:list={["nav-link", { active: isDocs }]}>Docs</a>
    <a href="/blog/" class:list={["nav-link", { active: isBlog }]}>Blog</a>
  </nav>
</div>

<style>
  @layer starlight.core {
    .flaglint-titlebar {
      align-items: center;
      gap: 1.25rem;
      min-width: 0;
    }

    .site-title {
      align-items: center;
      font-size: 1.375rem;
      font-weight: 800;
      letter-spacing: -0.03em;
      text-decoration: none;
      white-space: nowrap;
    }

    /* Two-color wordmark — dark mode (default header background is dark) */
    .brand-flag {
      color: #f5f7f6;
    }

    .brand-lint {
      color: #16e38b;
    }

    .product-nav {
      display: flex;
      align-items: center;
      gap: 0.25rem;
    }

    .nav-link {
      border-radius: 0.5rem;
      color: rgba(255, 255, 255, 0.72);
      font-size: 0.9375rem;
      font-weight: 600;
      padding: 0.5rem 0.625rem;
      text-decoration: none;
      transition: color 0.12s ease, background 0.12s ease;
    }

    .nav-link:hover {
      color: #ffffff;
      background: rgba(255, 255, 255, 0.08);
    }

    .nav-link.active {
      color: #16e38b;
      background: rgba(22, 227, 139, 0.10);
    }

    @media (max-width: 42rem) {
      .product-nav {
        display: none;
      }
    }
  }

  /* Light mode overrides */
  :global([data-theme="light"]) .brand-flag {
    color: #17201c;
  }

  :global([data-theme="light"]) .brand-lint {
    color: #08734f;
  }

  :global([data-theme="light"]) .nav-link {
    color: #46524c;
  }

  :global([data-theme="light"]) .nav-link:hover {
    color: #17201c;
    background: rgba(8, 115, 79, 0.08);
  }

  :global([data-theme="light"]) .nav-link.active {
    color: #08734f;
    background: rgba(8, 115, 79, 0.10);
  }
</style>
